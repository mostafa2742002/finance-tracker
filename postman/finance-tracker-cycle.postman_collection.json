{
  "info": {
    "_postman_id": "9c3798ca-5c4c-47c2-9f99-f1a4058d519a",
    "name": "Finance Tracker Full Cycle",
    "description": "Ordered requests to test the full backend cycle for the AI Finance Tracker project. Reports endpoints are intentionally excluded.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('email')) {",
          "  const random = Date.now();",
          "  pm.environment.set('email', `postman.${random}@example.com`);",
          "}",
          "if (!pm.environment.get('clientId')) {",
          "  pm.environment.set('clientId', pm.variables.replaceIn('{{$guid}}'));",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081"
    }
  ],
  "item": [
    {
      "name": "01 Authentication",
      "item": [
        {
          "name": "01 Signup",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const random = Date.now();",
                  "pm.environment.set('email', `postman.${random}@example.com`);",
                  "pm.environment.set('username', `PostmanUser${random}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup succeeded', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('accessToken', json.data.accessToken);",
                  "pm.environment.set('refreshToken', json.data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "signup"
              ]
            },
            "description": "Creates a fresh user for this run and stores access and refresh tokens."
          }
        },
        {
          "name": "02 Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('accessToken', json.data.accessToken);",
                  "pm.environment.set('refreshToken', json.data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Logs in with the same user and refreshes the token variables."
          }
        },
        {
          "name": "03 Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Refresh succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('accessToken', json.data.accessToken);",
                  "pm.environment.set('refreshToken', json.data.refreshToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "refresh"
              ]
            },
            "description": "Refreshes both tokens. Run this before protected requests if your access token expires."
          }
        }
      ]
    },
    {
      "name": "02 Budgets",
      "item": [
        {
          "name": "04 Create Or Update Budget",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Budget saved', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('budgetId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Food\",\n  \"limitAmount\": 500.00,\n  \"month\": 4,\n  \"year\": 2026\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/budgets",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "budgets"
              ]
            },
            "description": "Creates a budget for Food so the later transaction can participate in the budget and alert cycle."
          }
        },
        {
          "name": "05 Get Budgets For Month",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/budgets/4/2026",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "budgets",
                "4",
                "2026"
              ]
            },
            "description": "Checks that the budget exists before creating transactions."
          }
        }
      ]
    },
    {
      "name": "03 Transactions",
      "item": [
        {
          "name": "06 Create Transaction",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('clientId', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Transaction created', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.environment.set('transactionId', json.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 120.50,\n  \"description\": \"Weekly grocery shopping\",\n  \"category\": \"Food\",\n  \"type\": \"EXPENSE\",\n  \"date\": \"2026-04-01T12:30:00\",\n  \"clientId\": \"{{clientId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions"
              ]
            },
            "description": "Creates a transaction and stores the returned transaction identifier. This also triggers the async AI flow."
          }
        },
        {
          "name": "07 Get Transaction By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transactionId}}"
              ]
            },
            "description": "Reads the transaction directly. If the async AI listener already finished, you may see AI fields populated."
          }
        },
        {
          "name": "08 List Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions?category=Food&page=0&size=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "Food"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            },
            "description": "Lists transactions with a category filter to confirm pagination and filtering."
          }
        },
        {
          "name": "09 Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 145.75,\n  \"description\": \"Updated grocery run\",\n  \"category\": \"Food\",\n  \"type\": \"EXPENSE\",\n  \"date\": \"2026-04-01T18:45:00\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transactionId}}"
              ]
            },
            "description": "Updates the same transaction so you can verify the edit flow."
          }
        }
      ]
    },
    {
      "name": "04 Alerts",
      "item": [
        {
          "name": "10 Get Unread Alert Count",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/alerts/count/unread",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "alerts",
                "count",
                "unread"
              ]
            },
            "description": "Checks whether fraud or budget alerts were created by the earlier transaction flow."
          }
        },
        {
          "name": "11 List Alerts",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Alerts fetched', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "const alerts = json.data && json.data.content ? json.data.content : [];",
                  "if (alerts.length > 0) {",
                  "  pm.environment.set('alertId', alerts[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/alerts?isRead=false&page=0&size=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "alerts"
              ],
              "query": [
                {
                  "key": "isRead",
                  "value": "false"
                },
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            },
            "description": "Fetches unread alerts and stores the first alert identifier if one exists."
          }
        },
        {
          "name": "12 Mark First Alert As Read",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/alerts/{{alertId}}/read",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "alerts",
                "{{alertId}}",
                "read"
              ]
            },
            "description": "Marks the first unread alert as read. Run this only if the previous request stored an alert identifier."
          }
        },
        {
          "name": "13 Mark All Alerts As Read",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/alerts/read-all",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "alerts",
                "read-all"
              ]
            },
            "description": "Marks every alert as read for a clean end state."
          }
        }
      ]
    },
    {
      "name": "05 Cleanup",
      "item": [
        {
          "name": "14 Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions/{{transactionId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "transactions",
                "{{transactionId}}"
              ]
            },
            "description": "Deletes the transaction created earlier."
          }
        },
        {
          "name": "15 Delete Budget",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/budgets/{{budgetId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "budgets",
                "{{budgetId}}"
              ]
            },
            "description": "Deletes the budget created earlier."
          }
        },
        {
          "name": "16 Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Logout succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.environment.unset('accessToken');",
                  "pm.environment.unset('refreshToken');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "logout"
              ]
            },
            "description": "Logs out the current session and clears the stored tokens."
          }
        }
      ]
    }
  ]
}
